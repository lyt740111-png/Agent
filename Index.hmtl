<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>منشئ المشاريع الذكي | OpenRouter & GitHub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 p-4 md:p-8">

    <div class="max-w-4xl mx-auto space-y-6">
        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
            <h1 class="text-2xl font-bold mb-2 text-blue-600">منشئ المشاريع الذكي</h1>
            <p class="text-gray-600 text-sm">استخدم نماذج الذكاء الاصطناعي لتوليد الأكواد وتصديرها مباشرة إلى مستودعك في GitHub.</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
            <h2 class="text-lg font-semibold mb-4 border-b pb-2">الإعدادات (تُحفظ محلياً في المتصفح)</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm mb-1">مفتاح OpenRouter API</label>
                    <input type="password" id="openRouterKey" class="w-full border p-2 rounded focus:outline-none focus:border-blue-500" placeholder="sk-or-v1-...">
                </div>
                <div>
                    <label class="block text-sm mb-1">GitHub Access Token</label>
                    <input type="password" id="githubToken" class="w-full border p-2 rounded focus:outline-none focus:border-blue-500" placeholder="ghp_...">
                </div>
                <div>
                    <label class="block text-sm mb-1">اسم مستخدم GitHub</label>
                    <input type="text" id="githubUser" class="w-full border p-2 rounded focus:outline-none focus:border-blue-500" placeholder="مثال: Username">
                </div>
                <div>
                    <label class="block text-sm mb-1">اسم المستودع (Repository)</label>
                    <input type="text" id="githubRepo" class="w-full border p-2 rounded focus:outline-none focus:border-blue-500" placeholder="مثال: my-project">
                </div>
            </div>
            <button onclick="saveSettings()" class="mt-4 bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition text-sm">حفظ الإعدادات</button>
            <span id="saveStatus" class="text-green-600 text-sm mr-2 hidden">تم الحفظ بنجاح!</span>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
            <h2 class="text-lg font-semibold mb-4 border-b pb-2">توليد المشروع</h2>
            <label class="block text-sm mb-1">وصف المشروع أو الكود المطلوب</label>
            <textarea id="promptInput" rows="4" class="w-full border p-2 rounded focus:outline-none focus:border-blue-500 mb-4" placeholder="اكتب هنا ما تريد برمجته..."></textarea>
            
            <button onclick="generateCode()" id="generateBtn" class="bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 transition w-full md:w-auto">توليد الكود عبر الذكاء الاصطناعي</button>
            <p id="loadingMsg" class="text-blue-600 mt-2 text-sm hidden">جاري التوليد، يرجى الانتظار...</p>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200">
            <h2 class="text-lg font-semibold mb-4 border-b pb-2">النتيجة والتصدير</h2>
            <textarea id="resultOutput" rows="10" class="w-full border p-2 rounded focus:outline-none bg-gray-50 mb-4 font-mono text-left" dir="ltr" placeholder="سيظهر الكود المُولد هنا..."></textarea>
            
            <div class="flex flex-col md:flex-row gap-4 items-center bg-gray-50 p-4 rounded border">
                <div class="w-full md:w-1/2">
                    <label class="block text-sm mb-1">اسم الملف (مع الامتداد)</label>
                    <input type="text" id="filenameInput" class="w-full border p-2 rounded focus:outline-none text-left" dir="ltr" placeholder="مثال: app.js أو index.py">
                </div>
                <div class="w-full md:w-1/2 md:mt-6">
                    <button onclick="exportToGitHub()" id="exportBtn" class="bg-gray-800 text-white px-6 py-2 rounded hover:bg-gray-900 transition w-full">تصدير إلى GitHub</button>
                </div>
            </div>
            <p id="exportStatus" class="mt-2 text-sm font-semibold"></p>
        </div>
    </div>

    <script>
        // استرجاع الإعدادات عند تحميل الصفحة
        window.onload = function() {
            document.getElementById('openRouterKey').value = localStorage.getItem('openRouterKey') || '';
            document.getElementById('githubToken').value = localStorage.getItem('githubToken') || '';
            document.getElementById('githubUser').value = localStorage.getItem('githubUser') || '';
            document.getElementById('githubRepo').value = localStorage.getItem('githubRepo') || '';
        };

        // حفظ الإعدادات محلياً
        function saveSettings() {
            localStorage.setItem('openRouterKey', document.getElementById('openRouterKey').value);
            localStorage.setItem('githubToken', document.getElementById('githubToken').value);
            localStorage.setItem('githubUser', document.getElementById('githubUser').value);
            localStorage.setItem('githubRepo', document.getElementById('githubRepo').value);
            
            const status = document.getElementById('saveStatus');
            status.classList.remove('hidden');
            setTimeout(() => status.classList.add('hidden'), 3000);
        }

        // دالة التوليد باستخدام OpenRouter
        async function generateCode() {
            const apiKey = document.getElementById('openRouterKey').value;
            const prompt = document.getElementById('promptInput').value;
            const loadingMsg = document.getElementById('loadingMsg');
            const generateBtn = document.getElementById('generateBtn');
            const resultOutput = document.getElementById('resultOutput');

            if (!apiKey || !prompt) {
                alert('يرجى التأكد من إدخال مفتاح OpenRouter ووصف المشروع.');
                return;
            }

            loadingMsg.classList.remove('hidden');
            generateBtn.disabled = true;
            resultOutput.value = '';

            try {
                const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
                    method: 'POST',
                    headers: {
                        'Authorization': `Bearer ${apiKey}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        // استخدام نموذج مجاني متاح على OpenRouter
                        "model": "mistralai/mistral-7b-instruct:free",
                        "messages": [
                            {"role": "system", "content": "You are a professional software engineer. Output ONLY the requested code without any markdown formatting or explanations, unless asked otherwise."},
                            {"role": "user", "content": prompt}
                        ]
                    })
                });

                if (!response.ok) throw new Error('فشل الاتصال بـ OpenRouter');

                const data = await response.json();
                let generatedText = data.choices[0].message.content;
                
                // تنظيف النتيجة من علامات الماركداون إذا وجدت
                generatedText = generatedText.replace(/^```[a-z]*\n/gm, '').replace(/```$/gm, '');
                resultOutput.value = generatedText.trim();
            } catch (error) {
                alert('حدث خطأ أثناء التوليد: ' + error.message);
            } finally {
                loadingMsg.classList.add('hidden');
                generateBtn.disabled = false;
            }
        }

        // دالة التصدير إلى GitHub
        async function exportToGitHub() {
            const token = document.getElementById('githubToken').value;
            const user = document.getElementById('githubUser').value;
            const repo = document.getElementById('githubRepo').value;
            const content = document.getElementById('resultOutput').value;
            const filename = document.getElementById('filenameInput').value;
            const exportStatus = document.getElementById('exportStatus');

            if (!token || !user || !repo || !content || !filename) {
                alert('يرجى إكمال جميع حقول الإعدادات، واسم الملف، والتأكد من وجود كود للتصدير.');
                return;
            }

            exportStatus.textContent = 'جاري التصدير...';
            exportStatus.className = 'mt-2 text-sm text-blue-600 font-semibold';

            // تحويل النص إلى صيغة Base64 المتوافقة مع Unicode
            const base64Content = btoa(unescape(encodeURIComponent(content)));
            const url = `https://api.github.com/repos/${user}/${repo}/contents/${filename}`;

            try {
                // التحقق مما إذا كان الملف موجوداً مسبقاً لتحديثه (يتطلب SHA)
                let sha = '';
                const checkResponse = await fetch(url, {
                    headers: { 'Authorization': `token ${token}` }
                });
                if (checkResponse.ok) {
                    const fileData = await checkResponse.json();
                    sha = fileData.sha;
                }

                // تجهيز بيانات الرفع
                const bodyData = {
                    message: `إضافة/تحديث ${filename} عبر منشئ المشاريع`,
                    content: base64Content
                };
                if (sha) bodyData.sha = sha;

                // رفع الملف
                const putResponse = await fetch(url, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `token ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(bodyData)
                });

                if (putResponse.ok) {
                    exportStatus.textContent = 'تم التصدير إلى GitHub بنجاح!';
                    exportStatus.className = 'mt-2 text-sm text-green-600 font-semibold';
                } else {
                    const errorData = await putResponse.json();
                    throw new Error(errorData.message);
                }
            } catch (error) {
                exportStatus.textContent = 'خطأ في التصدير: ' + error.message;
                exportStatus.className = 'mt-2 text-sm text-red-600 font-semibold';
            }
        }
    </script>
</body>
</html>
